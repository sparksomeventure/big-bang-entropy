FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y \
    python3 \
    python3-flask \
    python3-pil \
    gunicorn \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY entropy_server.py .

EXPOSE 8080 1420 5005/udp

CMD ["gunicorn", "-w", "1", "--threads", "16", "-b", "0.0.0.0:8080", "entropy_server:app"]
